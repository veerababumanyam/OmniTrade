{
  "mcpServers": {
    "polygon-market-data": {
      "command": "node",
      "args": [
        "C:\\Users\\admin\\Desktop\\OmniTrade\\mcp\\polygon-market-data\\dist\\index.js"
      ],
      "env": {
        "POLYGON_API_KEY": "${POLYGON_API_KEY}"
      }
    },
    "sec-filings": {
      "command": "node",
      "args": [
        "C:\\Users\\admin\\Desktop\\OmniTrade\\mcp\\sec-filings\\dist\\index.js"
      ],
      "env": {
        "SEC_API_KEY": "${SEC_API_KEY}"
      }
    },
    "pgvector-server": {
      "command": "node",
      "args": [
        "C:\\Users\\admin\\Desktop\\OmniTrade\\mcp\\pgvector-server\\dist\\index.js"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "PGVECTOR_HOST": "${PGVECTOR_HOST}",
        "PGVECTOR_PORT": "5432",
        "PGVECTOR_DB": "${PGVECTOR_DB}",
        "PGVECTOR_USER": "${PGVECTOR_USER}",
        "PGVECTOR_PASSWORD": "${PGVECTOR_PASSWORD}"
      }
    },
    "alpaca-broker": {
      "command": "node",
      "args": [
        "C:\\Users\\admin\\Desktop\\OmniTrade\\mcp\\alpaca-broker\\dist\\index.js"
      ],
      "env": {
        "ALPACA_API_KEY": "${ALPACA_API_KEY}",
        "ALPACA_SECRET_KEY": "${ALPACA_SECRET_KEY}",
        "ALPACA_BASE_URL": "${ALPACA_BASE_URL}"
      }
    },
    "financial-news": {
      "command": "node",
      "args": [
        "C:\\Users\\admin\\Desktop\\OmniTrade\\mcp\\financial-news\\dist\\index.js"
      ],
      "env": {
        "ALPHA_VANTAGE_API_KEY": "${ALPHA_VANTAGE_API_KEY}",
        "NEWS_API_KEY": "${NEWS_API_KEY}"
      }
    },
    "kilo-indexer": {
      "command": "C:\\Users\\admin\\Desktop\\OmniTrade\\backend\\rag-indexer.exe",
      "args": [
        "--mcp",
        "--workspace",
        "C:\\Users\\admin\\Desktop\\OmniTrade"
      ],
      "env": {
        "EMBEDDING_BASE_URL": "http://localhost:12434/v1",
        "EMBEDDING_MODEL": "docker.io/ai/embeddinggemma:latest",
        "EMBEDDING_API_KEY": "not-needed",
        "DATABASE_URL": "postgresql://postgres:postgres@127.0.0.1:5432/omnitrade"
      }
    },
    "fmp": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sse",
        "https://financialmodelingprep.com/mcp?apikey=${FMP_API_KEY}"
      ]
    }
  }
}
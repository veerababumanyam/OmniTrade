# Database Connection Configuration
# Copy this file to .env and fill in your values

# Option 1: Full connection string (takes precedence)
# DATABASE_URL=postgresql://omnitrade_readonly:password@localhost:5432/omnitrade

# Option 2: Individual connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_USER=omnitrade_readonly
DB_PASSWORD=your_secure_password_here
DB_NAME=omnitrade

# Notes:
# - For AI agents (Intelligence Plane), use omnitrade_readonly role
# - For write operations (store_embedding), use a write-enabled role
# - Ensure pgvector extension is installed: CREATE EXTENSION IF NOT EXISTS vector;

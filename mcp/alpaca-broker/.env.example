# Alpaca Paper Trading API Credentials
# Get your API keys from: https://alpaca.markets/brokerage/dashboard

# Alpaca API Key (Key ID)
ALPACA_API_KEY=your_api_key_here

# Alpaca Secret Key
ALPACA_SECRET_KEY=your_secret_key_here

# Alpaca Base URL (Paper Trading Only!)
# IMPORTANT: Always use paper-api for testing. Never use live trading without proper risk management.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: Override default API version (default: v2)
# ALPACA_API_VERSION=v2

# Optional: Data source for portfolio history (default: paper accounts use paper data)
# ALPACA_DATA_FEED=ipas

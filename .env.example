# OmniTrade Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# MCP Server API Keys
# ===========================================

# Polygon.io - Market data API
POLYGON_API_KEY=your_polygon_api_key_here

# SEC API - SEC filings access
SEC_API_KEY=your_sec_api_key_here

# Alpha Vantage - Financial data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# News API - Financial news
NEWS_API_KEY=your_news_api_key_here

# Alpaca - Broker integration
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ===========================================
# Database Configuration
# ===========================================

DATABASE_URL=postgres://postgres:postgres@localhost:5432/omnitrade?sslmode=disable
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=omnitrade
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=postgres

# ===========================================
# Redis Configuration
# ===========================================

REDIS_URL=redis://localhost:6379

# ===========================================
# Backend Configuration
# ===========================================

DB_HOST=localhost
DB_USER=omnitrade_readonly
DB_PASSWORD=your_db_password_here
DB_NAME=omnitrade
PORT=8080

# ===========================================
# Claude Code Configuration (Optional)
# ===========================================

# ANTHROPIC_AUTH_TOKEN=your_token_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
